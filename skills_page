<!DOCTYPE html>
<html>
	<head>
		<title>skills</title>
		<style>
		header{
			background-color:pink;
			color:blue;
			height:40px;
			text-align:center;
			}

    body {
      font-family: Arial, sans-serif;
      margin: 20px;   
overflow: hidden; 
  margin: 0;
  padding: 0;
overflow-y: scroll; /* allows vertical scrolling */
  scrollbar-width: none; /* hides scrollbar in Firefox */
}
body::-webkit-scrollbar {
  display: none; /* hides scrollbar in Chrome, Edge, Safari */
 }
    button {
      padding: 60px 120px;
      margin: 50px;
      cursor: pointer;
      background-color:#f9f9f9;
      color: black;
      border: solidblack 2px;
      border-radius: 30px;
    }
.button-container {
  display: flex;
  justify-content: center; /* centers horizontally */
  gap: 50px; /* space between buttons */
  margin-top: 30px;
}
    .skills-section {
      display: none; /* hidden by default */
      margin-top: 10px;
      padding: 25px;
      border: 1px solid #ccc;
      border-radius: 30px;
      background: #f9f9f9;
    }
  </style>
	</head>
	<body>
		<header><h1>Skills</h1></header>
		<div class="button-container">
		<button onclick="toggleSection('technical')"><b>Technical Skills</button>
  <button onclick="toggleSection('nontechnical')"><b>Non-Technical Skills</button>
		</div>
  <div id="technical" class="skills-section">
    <h3>Technical Skills</h3>
    <ul>
	<li>C Programming</li>
	<li>Python Programming</li>
      <li>HTML & CSS</li>
      <li>JavaScript</li>
      <li>Salesforce Apex</li>
      <li>Networking Fundamentals</li>
    </ul>
  </div>

  <div id="nontechnical" class="skills-section">
    <h3>Non-Technical Skills</h3>
    <ul>
      <li>Communication</li>
      <li>Teamwork</li>
      <li>Problem-Solving</li>
      <li>Creativity</li>
    </ul>
  </div>

  <script>
    function toggleSection(sectionId) {
      const section = document.getElementById(sectionId);
      // Toggle visibility
      if (section.style.display === "block") {
        section.style.display = "none";
      } else {
        section.style.display = "block";
      }
    }
  </script>
	</body>
</html>
